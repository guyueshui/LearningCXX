    if (usec > max_duration)
      return max_duration;
    return static_cast<long>(usec);
  }


  per_timer_data* timers_;

  struct heap_entry
  {

    time_type time_;


    per_timer_data* timer_;
  };


  std::vector<heap_entry> heap_;
