    return &executor_;
  }

  const void* target() const noexcept(true)
  {
    return &executor_;
  }

  bool equals(const impl_base* e) const noexcept(true)
  {
    if (this == e)
      return true;
    if (target_type() != e->target_type())
      return false;
    return executor_ == *static_cast<const Executor*>(e->target());
  }

