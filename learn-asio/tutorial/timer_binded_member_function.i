    if (!(((static_cast<unsigned>(service->scheduler_.concurrency_hint()) & (0xFFFF0000u | 0x1u)) ^ 0xA5100000u) != 0)

        || !(((static_cast<unsigned>(state->service_list_->scheduler_.concurrency_hint()) & (0xFFFF0000u | 0x1u)) ^ 0xA5100000u) != 0))

